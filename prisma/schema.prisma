generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                   String                @id @default(uuid())
  name                 String?
  email                String                @unique
  emailVerified        Boolean               @default(false)
  image                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  role                 Role?                 @default(user)
  banned               Boolean?
  banReason            String?
  banExpires           Int?
  credits              Int                   @default(3)
  tier                 String                @default("FREE")
  stripeId             String?
  totalInterviews      Int                   @default(0)
  totalPracticeTime    Int                   @default(0)
  currentStreak        Int                   @default(0)
  longestStreak        Int                   @default(0)
  lastPracticeDate     DateTime?
  accounts             Account[]
  interviews           Interview[]
  resumes              Resume[]
  sessions             Session[]
  systemDesignAttempts SystemDesignAttempt[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  idToken               String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Resume {
  id         String      @id @default(uuid())
  userId     String
  title      String
  content    String
  fileUrl    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  interviews Interview[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resume")
}

model Interview {
  id              String                 @id @default(uuid())
  userId          String
  resumeId        String?
  status          InterviewStatus        @default(SETUP)
  type            InterviewType          @default(TECHNICAL)
  techStack       String?
  experienceLevel String                 @default("MID")
  companyName     String?
  jobTitle        String
  jobDescription  String?
  resumeText      String?
  includeDSA      Boolean                @default(false)
  jdEmbedding     Unsupported("vector")?
  startedAt       DateTime               @default(now())
  endedAt         DateTime?
  durationSec     Int                    @default(0)
  resume          Resume?                @relation(fields: [resumeId], references: [id])
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  report          Report?

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, startedAt])
  @@map("interview")
}

model Message {
  id          String      @id @default(uuid())
  interviewId String
  role        MessageRole
  content     String
  audioUrl    String?
  codeSnippet String?
  language    String?
  createdAt   DateTime    @default(now())
  interview   Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("message")
}

model Report {
  id             String    @id @default(uuid())
  interviewId    String    @unique
  overallScore   Int
  summary        String
  categoryScores Json
  strengths      String[]
  weaknesses     String[]
  suggestions    String[]
  createdAt      DateTime  @default(now())
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("report")
}

model SystemDesignProblem {
  id                String                @id @default(uuid())
  title             String
  description       String
  functionalReqs    String[]
  nonFunctionalReqs String[]
  complexity        String                @default("MEDIUM")
  createdBy         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  attempts          SystemDesignAttempt[]

  @@map("system_design_problem")
}

model SystemDesignAttempt {
  id               String              @id @default(uuid())
  problemId        String
  userId           String
  architectureJson Json
  aiFeedback       Json?
  score            Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  problem          SystemDesignProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([userId])
  @@map("system_design_attempt")
}

enum InterviewStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
}

enum MessageRole {
  system
  user
  assistant
}

enum Role {
  user
  admin
}
