// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credits  Int     @default(3)
  tier     String  @default("FREE")
  stripeId String?

  // analytics fields for quick stats
  totalInterviews   Int @default(0)
  totalPracticeTime Int @default(0) // in seconds
  currentStreak     Int @default(0) // consecutive days
  longestStreak     Int @default(0)
  lastPracticeDate  DateTime?

  sessions   Session[]
  accounts   Account[]
  resumes    Resume[]
  interviews Interview[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  idToken String?

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Resume {
  id      String  @id @default(uuid())
  userId  String
  title   String
  content String
  fileUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  interviews Interview[]

  @@index([userId])
  @@map("resume")
}

enum InterviewStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
}

model Interview {
  id       String  @id @default(uuid())
  userId   String
  resumeId String?

  status InterviewStatus @default(SETUP)
  type   InterviewType   @default(TECHNICAL)

  techStack       String?
  experienceLevel String  @default("MID")

  jobTitle       String
  jobDescription String?
  resumeText     String?
  includeDSA     Boolean @default(false)

  jdEmbedding Unsupported("vector(768)")?

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int       @default(0)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume   Resume?   @relation(fields: [resumeId], references: [id])
  messages Message[]
  report   Report?

  // indexes for analytics queries
  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, startedAt])
  @@map("interview")
}

enum Role {
  system
  user
  assistant
}

model Message {
  id          String  @id @default(uuid())
  interviewId String
  role        Role
  content     String
  audioUrl    String?
  codeSnippet String?
  language    String?

  createdAt DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("message")
}

model Report {
  id          String @id @default(uuid())
  interviewId String @unique

  overallScore Int    // 0-100
  summary      String

  // The json should follow like this:-
  //   {
  //   "communication": 85,
  //   "problemSolving": 78,
  //   "technicalKnowledge": 72,
  //   "systemDesign": 65,
  //   "codeQuality": 80,
  //   "timeManagement": 70
  // }

  categoryScores Json

  strengths  String[]
  weaknesses String[]

  // gemini will generate the improvement suggestions
  suggestions String[]

  createdAt DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("report")
}
